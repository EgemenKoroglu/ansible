<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Altyapı Zafiyet Raporu</title>
    <style>
        body {
            background-color: #0a0a0a;
            color: #eaeaea;
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 40px;
        }
        .container {
            max-width: 1200px;
            margin: 0 auto;
        }
        h1 {
            font-size: 32px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: -1px;
            border-bottom: 4px solid #ffffff;
            padding-bottom: 10px;
            margin-bottom: 40px;
            color: #ffffff;
        }
        .server-block {
            background-color: #141414;
            border: 1px solid #333333;
            margin-bottom: 40px;
            padding: 25px;
        }
        .server-title {
            font-size: 22px;
            font-weight: 700;
            color: #ffffff;
            margin-top: 0;
            margin-bottom: 20px;
            display: flex;
            justify-content: space-between;
        }
        table {
            width: 100%;
            border-collapse: collapse;
        }
        th {
            background-color: #ffffff;
            color: #000000;
            font-weight: 700;
            text-align: left;
            padding: 15px;
            text-transform: uppercase;
            font-size: 12px;
            letter-spacing: 1px;
        }
        td {
            border-bottom: 1px solid #2a2a2a;
            padding: 15px;
            font-size: 14px;
        }
        .severity-CRITICAL { color: #ff3b30; font-weight: bold; }
        .severity-HIGH { color: #ff9500; font-weight: bold; }
        .severity-MEDIUM { color: #ffcc00; }
        .severity-LOW { color: #34c759; }
        .no-vuln { color: #34c759; font-weight: bold; padding: 20px 0; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Altyapı Zafiyet ve Yama Durum Raporu</h1>
        
        {% set hosts = groups['all'] %}
        {% for host in hosts %}
            {% set report_path = '/tmp/trivy_reports/' + host + '.json' %}
            {% set file_content = lookup('file', report_path, errors='ignore') %}
            
            <div class="server-block">
                <div class="server-title">
                    <span>Sunucu: {{ host }}</span>
                </div>
                
                {% if file_content %}
                    {% set host_data = file_content | from_json %}
                    {% set has_vuln = false %}
                    
                    <table>
                        <thead>
                            <tr>
                                <th>CVE Kodu</th>
                                <th>Paket Adı</th>
                                <th>Risk</th>
                                <th>Yüklü Sürüm</th>
                                <th>Gerekli Yama (Fixed)</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for result in host_data.get('Results', []) %}
                            {% for vuln in result.get('Vulnerabilities', []) %}
                                <!-- Eski "if vuln.FixedVersion" yerine güvenli .get() metodunu kullanıyoruz -->
                                {% if vuln.get('FixedVersion') %}
                                    {% set has_vuln = true %}
                                    <tr>
                                        <td><strong>{{ vuln.VulnerabilityID }}</strong></td>
                                        <td>{{ vuln.PkgName }}</td>
                                        <td class="severity-{{ vuln.Severity }}">{{ vuln.Severity }}</td>
                                        <td>{{ vuln.InstalledVersion }}</td>
                                        <!-- Yazdırırken de aynı şekilde .get() kullanıyoruz -->
                                        <td>{{ vuln.get('FixedVersion') }}</td>
                                    </tr>
                                {% endif %}
                            {% endfor %}
                        {% endfor %}
                        </tbody>
                    </table>
                    
                    {% if not has_vuln %}
                        <div class="no-vuln">Bu sunucuda yaması eksik bir paket bulunmamaktadır. Sistem güvenli.</div>
                    {% endif %}
                {% else %}
                    <div class="severity-CRITICAL">Hata: Bu sunucuya ait tarama verisi okunamadı.</div>
                {% endif %}
            </div>
        {% endfor %}
    </div>
</body>
</html>